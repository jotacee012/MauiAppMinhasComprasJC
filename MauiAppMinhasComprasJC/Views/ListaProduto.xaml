<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasComprasJC.Views.ListaProduto"
             Title="Minhas Compras">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Novo" Command="{Binding NovoProdutoCommand}" />
    </ContentPage.ToolbarItems>

    <VerticalStackLayout Padding="15" Spacing="15">

        <!-- FILTRO POR CATEGORIA -->
        <Picker 
            Title="Filtrar por categoria"
            ItemsSource="{Binding Categorias}"
            SelectedItem="{Binding CategoriaSelecionada}" />

        <!-- LISTA DE PRODUTOS -->
        <CollectionView 
            ItemsSource="{Binding Produtos}"
            x:Name="lst_produtos">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="LightGray" Padding="10" Margin="0,5">
                        <VerticalStackLayout>

                            <Label 
                                Text="{Binding Descricao}" 
                                FontAttributes="Bold"
                                FontSize="18" />

                            <Label 
                                Text="{Binding Categoria}" 
                                FontSize="14"
                                TextColor="Gray" />

                            <Label 
                                Text="{Binding Total, StringFormat='Total: R$ {0:F2}'}"
                                FontSize="16"
                                TextColor="DarkGreen" />

                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>