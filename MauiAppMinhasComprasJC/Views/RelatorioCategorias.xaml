<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MauiAppMinhasComprasJC.Views.RelatorioCategorias"
    Title="Relatório por Categoria">

    <VerticalStackLayout Padding="20">

        <CollectionView ItemsSource="{Binding Relatorio}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="LightGray" Padding="10" Margin="0,5">
                        <VerticalStackLayout>
                            <Label Text="{Binding Categoria}" FontAttributes="Bold" />
                            <Label Text="{Binding Total, StringFormat='Total: R$ {0:F2}'}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>