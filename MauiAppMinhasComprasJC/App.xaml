 ﻿<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="MauiAppMinhasComprasJC.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:MauiAppMinhasComprasJC.Views">

    <FlyoutItem Title="Minhas Compras">
        <ShellContent
            Title="Produtos"
            ContentTemplate="{DataTemplate views:ListaProduto}" />
    </FlyoutItem>

    <FlyoutItem Title="Relatórios">
        <ShellContent
            Title="Por Categoria"
            ContentTemplate="{DataTemplate views:RelatorioCategorias}" />
    </FlyoutItem>

</Shell>